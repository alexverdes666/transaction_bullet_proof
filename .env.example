# ---------------------------------------------------------------------------
# RPC + Fork configuration
# ---------------------------------------------------------------------------
# Upstream archive/full node the local Anvil fork mirrors. Use a mainnet RPC.
# A COMMA-SEPARATED list enables automatic round-robin failover (recommended,
# since free public RPCs are flaky and a dropped fetch can cause a false verdict).
# For reliable results prefer a dedicated key, e.g. Alchemy/Infura.
FORK_RPC_URL=https://ethereum-rpc.publicnode.com,https://eth.drpc.org,https://rpc.ankr.com/eth

# Pin to a block for fully reproducible diffs. Leave blank for "latest".
FORK_BLOCK_NUMBER=

# Local port Anvil listens on.
ANVIL_PORT=8545

# Path to the `anvil` binary. If it's on PATH just leave "anvil".
# Windows (foundryup): typically %USERPROFILE%\.foundry\bin\anvil.exe
ANVIL_BIN=anvil

# Chain id of the fork (1 = Ethereum mainnet).
CHAIN_ID=1

# ---------------------------------------------------------------------------
# DEX routing (Ethereum mainnet defaults — Uniswap V2)
# ---------------------------------------------------------------------------
ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ---------------------------------------------------------------------------
# Test wallet (anvil deterministic dev key — NEVER use on a real network)
# ---------------------------------------------------------------------------
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
FUND_ETH=100

# Amount of ETH to spend on the simulated buy.
BUY_ETH=1

# ---------------------------------------------------------------------------
# Control server (Node <-> Python orchestration)
# ---------------------------------------------------------------------------
CONTROL_PORT=8645
MOCK_DAPP_PORT=8700

# Shared secret required on POST /scan when the worker is deployed publicly
# (e.g. Render). Must match WORKER_SHARED_SECRET in the web app. Leave blank
# locally to allow the CLI/orchestrator to call the server without a secret.
WORKER_SHARED_SECRET=

# ---------------------------------------------------------------------------
# Python / Camoufox
# ---------------------------------------------------------------------------
PYTHON_BIN=python
HEADLESS=true
