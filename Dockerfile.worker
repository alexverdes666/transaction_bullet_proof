# ---------------------------------------------------------------------------
# Scan worker image (deploy to Render as a Web Service / Docker).
#
# Bundles Foundry (anvil) + the Node/TypeScript engine and serves the internal
# control API (src/server.ts). Protect it with WORKER_SHARED_SECRET; only the
# Next.js app (Vercel) should ever call it.
# ---------------------------------------------------------------------------
# DEP-4 (supply chain): for production the base image SHOULD be pinned by digest,
# e.g. `FROM node:22-bookworm-slim@sha256:<digest>`, so the build is reproducible
# and immune to a re-tagged upstream. The digest cannot be resolved offline here,
# so the tag is left in place with this TODO. Current tag: node:22-bookworm-slim.
# TODO(prod): pin to node:22-bookworm-slim@sha256:<resolved-digest>.
FROM node:22-bookworm-slim

# System deps: curl/git for foundryup, ca-certificates for HTTPS RPC.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Foundry (anvil, cast, forge).
# DEP-3 (supply chain): pin Foundry to a specific release instead of pulling
# whatever "latest" foundryup resolves at build time, so anvil is reproducible.
# Project line is Foundry 1.7.x (see CLAUDE.md §11). Bump deliberately.
ENV FOUNDRY_VERSION="v1.7.0"
ENV PATH="/root/.foundry/bin:${PATH}"
RUN curl -L https://foundry.paradigm.xyz | bash && foundryup --install "${FOUNDRY_VERSION}"

WORKDIR /app

# Install Node deps first for better layer caching.
COPY package.json package-lock.json ./
RUN npm ci

# App source.
COPY tsconfig.json ./
COPY src ./src

# Point the engine at the foundry-installed anvil and listen on Render's PORT.
ENV ANVIL_BIN=/root/.foundry/bin/anvil
ENV NODE_ENV=production
EXPOSE 8645

# DEP-5 (supply chain): run the local tsx binary directly (installed by `npm ci`
# above) instead of `npx tsx`, so nothing is resolved/fetched from the network at
# container start. tsx must be present in node_modules (it is a devDependency).
CMD ["node_modules/.bin/tsx", "src/server.ts"]
